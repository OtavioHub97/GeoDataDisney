<Window x:Class="GeoDataDisney.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GeoDataDisney.ViewModels"
        Title="Disney Character Explorer" Height="642" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#004e92" Offset="0"/>
                    <GradientStop Color="#000428" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🏰 Disney Characters" Foreground="White" FontSize="28" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                <TextBlock Text="API Explorer" Foreground="#88FFFFFF" FontSize="14" Margin="15,10,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
<TextBlock Grid.Row="1" Text="{Binding StatusMessage}" FontSize="18" FontWeight="Bold" 
           Foreground="#555555" HorizontalAlignment="Center" Margin="0,20,0,0" />
        

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <ItemsControl ItemsSource="{Binding Characters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="280" Margin="10" Background="White" CornerRadius="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="15,15,0,0" Margin="5">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Content="Ver Detalhes" 
                                      Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         CommandParameter="{Binding}"
                                           Margin="0,10,0,0" Background="#004e92" Foreground="White" BorderThickness="0" Padding="10,5">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>